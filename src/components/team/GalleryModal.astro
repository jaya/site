---
---

<div class="gallery-modal" id="gallery-modal">
	<button class="modal-close" id="modal-close" aria-label="Close modal">
		<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<line x1="18" y1="6" x2="6" y2="18"></line>
			<line x1="6" y1="6" x2="18" y2="18"></line>
		</svg>
	</button>
	
	<button class="modal-nav-btn prev" id="modal-prev" aria-label="Previous image">
		<svg width="32" height="32" viewBox="0 0 24 24" fill="none">
			<path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
		</svg>
	</button>

	<button class="modal-nav-btn next" id="modal-next" aria-label="Next image">
		<svg width="32" height="32" viewBox="0 0 24 24" fill="none">
			<path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
		</svg>
	</button>

	<div class="modal-content">
		<img src="" alt="Gallery Preview" id="modal-image" />
	</div>
</div>

<style>
	@reference '@/styles/global.css';

	.gallery-modal {
		@apply fixed inset-0 z-50 flex items-center justify-center bg-black/95 opacity-0 pointer-events-none transition-opacity duration-300 p-4 md:p-10;
		&.open { @apply opacity-100 pointer-events-auto; }
	}

	.modal-content {
		@apply relative max-w-full max-h-full rounded-xl overflow-hidden shadow-2xl flex items-center justify-center;
		img { @apply max-h-[85vh] max-w-[90vw] object-contain; }
	}

	.modal-close {
		@apply absolute top-6 right-6 text-white/50 hover:text-white w-12 h-12 bg-white/5 hover:bg-white/10 rounded-full flex items-center justify-center cursor-pointer transition-all z-50;
		&:hover { @apply scale-110; }
	}

	.modal-nav-btn {
		@apply absolute top-1/2 -translate-y-1/2 w-14 h-14 flex items-center justify-center text-white/40 hover:text-white bg-white/5 hover:bg-white/10 rounded-full transition-all z-50 cursor-pointer;
		&.prev { @apply left-6; }
		&.next { @apply right-6; }
		&:hover { @apply scale-110; }
	}
</style>

<script>
	const modal = document.getElementById('gallery-modal');
	const modalImg = document.getElementById('modal-image') as HTMLImageElement;
	const closeBtn = document.getElementById('modal-close');
	const modalPrevBtn = document.getElementById('modal-prev');
	const modalNextBtn = document.getElementById('modal-next');
	
	// Helper to find all items dynamically
	const getItems = () => document.querySelectorAll('.gallery-item');
	
	let currentImageIndex = 0;

	const updateModalImage = (index: number) => {
		const items = getItems();
		const item = items[index];
		const src = item?.getAttribute('data-full-src');
		if (src && modalImg) {
			modalImg.src = src;
			currentImageIndex = index;
		}
	}

	const openModal = (index: number) => {
		if (modal) {
			updateModalImage(index);
			modal.classList.add('open');
			document.body.style.overflow = 'hidden';
		}
	};

	const closeModal = () => {
		if (modal) {
			modal.classList.remove('open');
			document.body.style.overflow = '';
			setTimeout(() => { if (modalImg) modalImg.src = ''; }, 300);
		}
	};

	const navPrev = (e?: Event) => {
		e?.stopPropagation();
		const total = getItems().length;
		updateModalImage((currentImageIndex - 1 + total) % total);
	};

	const navNext = (e?: Event) => {
		e?.stopPropagation();
		const total = getItems().length;
		updateModalImage((currentImageIndex + 1) % total);
	};

	// Event delegation or individual listeners
	// For simplicity with dynamic Astro, we use a MutationObserver or just global listeners
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		const item = target.closest('.gallery-item');
		if (item) {
			const index = parseInt(item.getAttribute('data-index') || '0');
			openModal(index);
		}
	});

	closeBtn?.addEventListener('click', closeModal);
	modalPrevBtn?.addEventListener('click', navPrev);
	modalNextBtn?.addEventListener('click', navNext);

	modal?.addEventListener('click', (e) => {
		if (e.target === modal) closeModal();
	});

	document.addEventListener('keydown', (e) => {
		if (!modal?.classList.contains('open')) return;
		if (e.key === 'Escape') closeModal();
		else if (e.key === 'ArrowLeft') navPrev();
		else if (e.key === 'ArrowRight') navNext();
	});
</script>
