---
import type { ImageMetadata } from 'astro'
import { socialLinks } from '@/data/social-links'
import { getTranslations, t } from '@/i18n/translations'
import { getLocale, type Locale } from '@/i18n/utils'

const { locale: propLocale } = Astro.props as { locale?: Locale }
const locale = propLocale ?? getLocale(Astro)
const translations = await getTranslations(locale)

// Import all images from the team directory
const teamImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/culture/team/*.{jpeg,jpg,png,webp,svg}', { eager: true });

function formatName(slug: string) {
	return slug
		.split(/[-_]/)
		.map(word => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');
}

// Map of manual overrides for names, roles, and descriptions
const peopleOverrides: Record<string, Partial<{ name: string, role: string, desc: string }>> = {
