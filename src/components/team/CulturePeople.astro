	'edu-tercio': { name: 'Eduardo Tercio', role: '', desc: '' },
	'emanuel': { name: 'Emanuel Batista', role: 'Backwoods Samurai', desc: "That's just it" },
	'fernando-ferreira': { name: 'Fernando Ferreira', role: 'Frontend engineer', desc: 'Fixing more than breaking' },
	'francisco-junior': { name: 'Francisco Junior', role: '', desc: '' },
	'gabriel-mendes': { name: 'Gabriel Mendes', role: '', desc: '' },
	'gabriel': { name: 'Gabriel Silva', role: 'Spaces > tabs', desc: 'Takes two hours to name variables.' },
	'georgeo': { name: 'Georgeo Rocco', role: '', desc: '' },
