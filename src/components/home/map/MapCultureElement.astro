</svg>

<script>
  function updatePinSizes() {
    // Wait for fonts to load to ensure correct BBox calculations
    document.fonts.ready.then(() => {
      const pins = document.querySelectorAll('.map-pin');
      pins.forEach(g => {
        const text = g.querySelector('text');
        const rect = g.querySelector('rect');
        const line = g.querySelector('line');
        if (!text || !rect || !line) return;

        // Get the position and line length from data attributes
        const position = g.getAttribute('data-position') || 'top-right';
        const lineLength = parseInt(g.getAttribute('data-line-length') || '15', 10);

        // Reset text position to calculate bbox
        text.setAttribute('x', '0');
        text.setAttribute('y', '0');

        const bbox = text.getBBox();
        const paddingX = 5;
        const paddingY = 2;
        
        // Calculate dimensions
        const width = bbox.width + (paddingX * 2);
        const height = bbox.height + (paddingY * 2);
        const radius = height / 2; // Border radius
        
        // Update rect size
        rect.setAttribute('width', width.toString());
        rect.setAttribute('height', height.toString());
        rect.setAttribute('rx', radius.toString());
        
        // Determine line orientation based on position
        const isTop = position.startsWith('top');
        const isBottom = position.startsWith('bottom');
        const isLeft = position === 'left';
        const isRight = position === 'right';
        const isHorizontal = isLeft || isRight;
        
        // Line direction changes based on position:
        // - top positions: line points UP (0,0) to (0,-lineLength)
        // - bottom positions: line points DOWN (0,0) to (0,lineLength)
        // - left position: line points LEFT (0,0) to (-lineLength,0)
        // - right position: line points RIGHT (0,0) to (lineLength,0)
        if (isHorizontal) {
          line.setAttribute('x1', '0');
          line.setAttribute('y1', '0');
          line.setAttribute('x2', isLeft ? (-lineLength).toString() : lineLength.toString());
          line.setAttribute('y2', '0');
        } else {
          line.setAttribute('x1', '0');
          line.setAttribute('y1', '0');
          line.setAttribute('x2', '0');
          line.setAttribute('y2', isTop ? (-lineLength).toString() : lineLength.toString());
        }
        
        // Position rect and text based on position prop
        // The rect should align with the line (x=0 or y=0)
        // Text should be centered inside the rect
        
        const gap = -3; // Gap between line endpoint and rect
        const cornerOffset = 2; // Offset to account for rounded corners
        let rectX, rectY, textX, textY;
        
        if (isHorizontal) {
          // Horizontal positions (left/right)
          const lineEnd = isLeft ? -lineLength : lineLength; // Line endpoint X coordinate
          
          if (isLeft) {
            // Rect extends to the LEFT from the line endpoint
            rectX = lineEnd - gap - width;
            rectY = -(height / 2);
            textX = lineEnd - gap - width / 2;
            textY = 0;
          } else { // isRight
            // Rect extends to the RIGHT from the line endpoint
            rectX = lineEnd + gap;
            rectY = -(height / 2);
            textX = lineEnd + gap + width / 2;
            textY = 0;
          }
        } else {
          // Vertical positions (top/bottom)
          const lineEnd = isTop ? -lineLength : lineLength; // Line endpoint Y coordinate
          
          switch(position) {
            case 'top-left':
              // Rect extends to the LEFT from the line endpoint
              rectX = -width + cornerOffset;
              rectY = lineEnd - gap - height;
              textX = -width / 2 + cornerOffset;
              textY = lineEnd - gap - height / 2;
              break;
              
            case 'top-right':
              // Rect extends to the RIGHT from the line endpoint
              rectX = -cornerOffset;
              rectY = lineEnd - gap - height;
              textX = width / 2 - cornerOffset;
              textY = lineEnd - gap - height / 2;
              break;
              
            case 'bottom-left':
              // Rect extends to the LEFT from the line endpoint
              rectX = -width + cornerOffset;
              rectY = lineEnd + gap;
              textX = -width / 2 + cornerOffset;
              textY = lineEnd + gap + height / 2;
              break;
              
            case 'bottom-right':
              // Rect extends to the RIGHT from the line endpoint
              rectX = -cornerOffset;
              rectY = lineEnd + gap;
              textX = width / 2 - cornerOffset;
              textY = lineEnd + gap + height / 2;
              break;
              
            default:
              // Default to top-right
              rectX = -cornerOffset;
              rectY = lineEnd - gap - height;
              textX = width / 2 - cornerOffset;
              textY = lineEnd - gap - height / 2;
          }
        }
        
        // Apply positions
        rect.setAttribute('x', rectX.toString());
        rect.setAttribute('y', rectY.toString());
        text.setAttribute('x', textX.toString());
        text.setAttribute('y', textY.toString());
      });
    });
  }

  // Run on load and after view transitions
  document.addEventListener('astro:page-load', updatePinSizes);
  document.addEventListener('DOMContentLoaded', updatePinSizes);
  updatePinSizes();
</script>