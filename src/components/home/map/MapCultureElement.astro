      pins.map((pin) => (
        <g class="map-pin" transform={`translate(${pin.x}, ${pin.y})`} aria-label={pin.label} data-position={pin.position || 'top-right'} data-line-length={pin.lineLength || 15}>
          <title>{pin.title}</title>
          <line x1="0" y1="0" x2="0" y2="-15" />
          <rect x="-6" y="-37" width="56" height="22" rx="11" />
          <text x="0" y="-16" dy="0.35em">
            {pin.label}
          </text>
        </g>
      ))
