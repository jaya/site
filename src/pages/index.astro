---
import { localeBr, localeEn } from '@/i18n/utils'

export const prerender = false

const cookie = Astro.request.headers.get('cookie') ?? ''
const langCookieRegex = new RegExp(`(?:^|;\\s*)lang=(${localeBr}|${localeEn})(?:;|$)`)
const match = cookie.match(langCookieRegex)

// 1. High Priority: Previous user choice (Cookie)
if (match?.[1]) {
	return Astro.redirect(`/${match[1]}/`, 307)
}

// 2. Medium Priority: Geolocation (DigitalOcean IP header)
const userIP = Astro.request.headers.get('do-connecting-ip')
let ipCountry = null

if (userIP) {
	try {
		const token = import.meta.env.IPINFO_TOKEN
		// Use ipinfo.io for geolocation
		const response = await fetch(`https://ipinfo.io/${userIP}/json?token=${token}`, {
			signal: AbortSignal.timeout(1500) // 1.5s timeout to not hang the user
		})
		if (response.ok) {
			const data = await response.json()
			ipCountry = data.country
		}
	} catch (e) {
		console.error('Geolocation error:', e)
	}
}

// 3. Fallback Priority: Browser language
const acceptLanguage = (Astro.request.headers.get('accept-language') ?? '').toLowerCase()
const prefersBrByNav = acceptLanguage.includes('pt')

// Final decision logic:
// If we have a country from IP, that is the rule: BR -> br, Others -> en.
// If we DON'T have IP info, we fall back to the browser language.
let lang;
if (ipCountry) {
	lang = ipCountry === 'BR' ? localeBr : localeEn
} else {
	lang = prefersBrByNav ? localeBr : localeEn
}

// Persist the decision in a cookie and use a non-permanent redirect.
return new Response(null, {
	status: 307,
	headers: {
		Location: `/${lang}/`,
		'Set-Cookie': `lang=${lang}; Path=/; Max-Age=31536000; SameSite=Lax; Secure`,
		Vary: 'Accept-Language, do-connecting-ip'
	}
})
---
