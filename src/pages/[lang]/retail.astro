---
import { getLocaleParam, locales } from '@/i18n/utils'
import RetailPage from '../_shared/RetailPage.astro'

export function getStaticPaths() {
	return locales.map((lang) => ({ params: { lang } }))
}

const lang = getLocaleParam(Astro.params.lang, locales)
if (!lang) {
	return new Response(null, { status: 404 })
}
---

<RetailPage locale={lang} />
