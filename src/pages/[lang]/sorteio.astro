---
import { getLocaleParam, localeBr } from '@/i18n/utils'
import heroLogo from '@/assets/sorteio/logo-jaya-hero-lp.png'
import footerLogo from '@/assets/sorteio/logo-jaya-footer.png'
import raybanImage from '@/assets/sorteio/rayban-jaya-sorteio.png'

export function getStaticPaths() {
	return [{ params: { lang: localeBr } }]
}

const lang = getLocaleParam(Astro.params.lang, [localeBr])
if (!lang) {
	return new Response(null, { status: 404 })
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jaya no Tropical on Rails — Sorteio Ray-Ban Meta</title>
  <meta name="description" content="Participe do sorteio da Jaya no Tropical on Rails e concorra a um Ray-Ban Meta." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    /* ─── TOKENS ───────────────────────────────────────── */
    :root {
      --teal:        #009aa0;
      --teal-dark:   #007a80;
      --teal-deeper: #006166;
      --teal-light:  #0ab5bb;
      --red:         #d42b2b;
      --red-hover:   #b52222;
      --white:       #ffffff;
      --off-white:   #f4fafa;
      --text-dark:   #0d2b2c;
      --text-body:   #1a3f40;
      --text-muted:  rgba(255,255,255,0.65);
      --border-white: rgba(255,255,255,0.18);
      --font-display: 'Space Grotesk', sans-serif;
      --font-body:    'Space Grotesk', sans-serif;
      --radius:       8px;
      --radius-lg:    16px;
      --radius-pill:  100px;
      --max-w:        1080px;
      --trans:        0.22s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ─── RESET ────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--teal);
      color: var(--white);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* ─── NOISE TEXTURE ────────────────────────────────── */
    /* subtle grain that matches the original */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
      background-size: 200px 200px;
    }
    * { position: relative; z-index: 1; }

    /* ─── HEADER ───────────────────────────────────────── */
    header {
      background: var(--teal-dark);
      border-bottom: 1px solid var(--border-white);
      padding: 0 32px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-logo {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .header-logo .jaya-wordmark {
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--white);
      letter-spacing: -0.04em;
    }
    .header-logo .sep {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
      letter-spacing: 0.04em;
    }
    .header-logo .event-name {
      display: flex;
      flex-direction: column;
      line-height: 1.15;
    }
    .header-logo .event-name strong {
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--white);
    }
    .header-logo .event-name span {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 500;
    }
    .header-logo-img {
      height: 40px;
      width: auto;
      display: block;
    }
    .footer-logo-img {
      height: 56px;
      width: auto;
      display: block;
    }
    .btn-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 9px 22px;
      background: var(--red);
      color: var(--white);
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 0.82rem;
      letter-spacing: 0.05em;
      border-radius: var(--radius-pill);
      border: none;
      cursor: pointer;
      transition: background var(--trans), transform var(--trans);
      text-decoration: none;
    }
    .btn-pill:hover {
      background: var(--red-hover);
      transform: translateY(-1px);
    }

    /* ─── HERO ─────────────────────────────────────────── */
    .hero {
      padding: 72px 32px 80px;
      max-width: var(--max-w);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .hero-left {}
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4.5vw, 3.1rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--white);
      margin-bottom: 40px;
    }
    .hero-title em {
      font-style: normal;
      color: var(--red);
    }

    /* Steps */
    .steps {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .step {
      display: flex;
      gap: 20px;
      padding: 22px 0;
      border-bottom: 1px solid var(--border-white);
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--red);
      line-height: 1;
      min-width: 28px;
      padding-top: 2px;
    }
    .step-text {
      font-size: 0.97rem;
      line-height: 1.6;
      color: var(--white);
    }
    .step-text strong { font-weight: 700; }

    /* Hero right: product + form */
    .hero-right {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .product-image {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
    .rayban-logo {
      font-size: 0.75rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .rayban-glasses {
      width: 300px;
      max-width: 100%;
      mix-blend-mode: lighten;
    }

    /* Form */
    .form-card {
      background: var(--teal-dark);
      border: 1px solid var(--border-white);
      border-radius: var(--radius-lg);
      padding: 32px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 16px;
    }
    .form-group:last-of-type { margin-bottom: 24px; }
    label {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--white);
      letter-spacing: 0.03em;
    }
    input[type="text"],
    input[type="email"] {
      width: 100%;
      padding: 12px 16px;
      background: var(--white);
      border: none;
      border-radius: var(--radius);
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--text-dark);
      outline: none;
      transition: box-shadow var(--trans);
    }
    input[type="text"]:focus,
    input[type="email"]:focus {
      box-shadow: 0 0 0 3px rgba(255,255,255,0.3);
    }
    input::placeholder { color: #aaa; }

    .btn-submit {
      width: 100%;
      padding: 15px;
      background: var(--red);
      color: var(--white);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 0.03em;
      border: none;
      border-radius: var(--radius-pill);
      cursor: pointer;
      transition: background var(--trans), transform var(--trans);
    }
    .btn-submit:hover {
      background: var(--red-hover);
      transform: translateY(-2px);
    }

    /* Social handles */
    .social-row {
      display: flex;
      gap: 20px;
      justify-content: center;
      margin-top: 16px;
    }
    .social-handle {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--white);
      text-decoration: none;
      transition: opacity var(--trans);
    }
    .social-handle:hover { opacity: 0.75; }
    .social-icon {
      width: 22px;
      height: 22px;
      background: rgba(255,255,255,0.15);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      font-weight: 700;
    }

    /* Regras */
    .regras {
      font-size: 0.72rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-top: 4px;
    }

    /* ─── DIVIDER ───────────────────────────────────────── */
    .wave-divider {
      width: 100%;
      overflow: hidden;
      line-height: 0;
      transform: rotate(180deg);
    }

    /* ─── PERGUNTAS ─────────────────────────────────────── */
    .perguntas {
      padding: 80px 32px;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      text-align: center;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .section-intro {
      text-align: center;
      font-size: 0.97rem;
      line-height: 1.75;
      color: rgba(255,255,255,0.85);
      max-width: 680px;
      margin: 0 auto 56px;
    }
    .section-intro strong {
      color: var(--white);
      font-weight: 700;
    }

    /* Value cards */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 48px;
    }
    .value-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      padding: 28px 24px;
      position: relative;
      box-shadow: 0 8px 32px rgba(0,0,0,0.15);
      transition: transform var(--trans), box-shadow var(--trans);
    }
    .value-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 48px rgba(0,0,0,0.2);
    }
    /* Slight tilt variation */
    .value-card:nth-child(1) { transform: rotate(-1.2deg); }
    .value-card:nth-child(1):hover { transform: rotate(-1.2deg) translateY(-4px); }
    .value-card:nth-child(3) { transform: rotate(1deg); }
    .value-card:nth-child(3):hover { transform: rotate(1deg) translateY(-4px); }
    .value-title {
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--teal);
      text-transform: uppercase;
      letter-spacing: -0.01em;
      margin-bottom: 12px;
      line-height: 1.2;
    }
    .value-desc {
      font-size: 0.82rem;
      color: var(--text-body);
      line-height: 1.65;
    }

    /* Pergunta items below cards */
    .perguntas-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 48px;
    }
    .pergunta-item {
      text-align: center;
    }
    .pergunta-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 10px;
    }
    .pergunta-text {
      font-family: var(--font-display);
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--white);
    }
    .perguntas-cta {
      text-align: center;
    }

    /* ─── WHITE SECTION ─────────────────────────────────── */
    .white-section {
      background: var(--white);
      padding: 80px 32px;
    }
    .white-section-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
    .ws-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 8px;
    }
    .ws-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--text-dark);
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }
    .ws-subtitle {
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--teal);
      margin-bottom: 20px;
      line-height: 1.5;
    }
    .ws-body {
      font-size: 0.95rem;
      color: var(--text-body);
      line-height: 1.8;
    }
    .ws-body p + p { margin-top: 1em; }
    .ws-cta {
      margin-top: 28px;
    }

    /* ─── FOOTER / LOGO ─────────────────────────────────── */
    .footer-logo-section {
      background: var(--white);
      border-top: 1px solid rgba(0,122,128,0.12);
      padding: 40px 32px;
      display: flex;
      justify-content: flex-end;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .footer-jaya-logo {
      font-family: var(--font-display);
      font-size: 2.8rem;
      font-weight: 700;
      color: var(--teal);
      letter-spacing: -0.04em;
    }

    /* ─── ANIMATIONS ────────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-title   { animation: fadeUp 0.55s ease both; }
    .steps        { animation: fadeUp 0.55s 0.1s ease both; }
    .hero-right   { animation: fadeUp 0.55s 0.15s ease both; }

    /* ─── RESPONSIVE ────────────────────────────────────── */
    @media (max-width: 840px) {
      .hero {
        grid-template-columns: 1fr;
        padding: 48px 24px 56px;
      }
      .cards-grid,
      .perguntas-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .value-card:nth-child(1),
      .value-card:nth-child(3) { transform: none; }
      .white-section-inner {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .footer-logo-section {
        justify-content: center;
      }
      header { padding: 0 20px; }
      .perguntas { padding: 56px 24px; }
      .white-section { padding: 56px 24px; }
    }
    @media (max-width: 480px) {
      .header-logo .event-name { display: none; }
      .header-logo .sep { display: none; }
    }
  </style>
</head>
<body>

  <!-- ── HEADER ──────────────────────────────────────────── -->
  <header>
    <div class="header-logo">
      <a href="https://jaya.tech/br/" aria-label="Jaya home">
        <img src={heroLogo.src} alt="Jaya no Tropical On Rails" class="header-logo-img" />
      </a>
    </div>

    <a href="https://jaya.vagas.flashapp.com.br/desenvolvedor-ruby-on-rails-984" class="btn-pill" target="_blank" rel="noopener">Vaga Ruby</a>
  </header>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section style="background: var(--teal);">
    <div class="hero">

      <!-- Left: title + steps -->
      <div class="hero-left">
        <h1 class="hero-title">
          Participe<br/>
          do sorteio e<br/>
          concorra a um<br/>
          Ray-Ban Meta
        </h1>

        <ol class="steps">
          <li class="step">
            <span class="step-num">1.</span>
            <p class="step-text">
              Escolha uma das perguntas e <strong>escreva a resposta no painel</strong>
            </p>
          </li>
          <li class="step">
            <span class="step-num">2.</span>
            <p class="step-text">
              Tire uma <strong>foto no stand da Jaya</strong> ou da sua
              <strong>resposta no painel e post no LinkedIn</strong> ou
              <strong>Instagram</strong> com a <strong>#jayaTropicalOnRails</strong>
            </p>
          </li>
          <li class="step">
            <span class="step-num">3.</span>
            <p class="step-text">
              Preencha o formulário corretamente e aguarde o sorteio no final do evento.
            </p>
          </li>
        </ol>
      </div>

      <!-- Right: product image + form -->
      <div class="hero-right">

        <!-- Ray-Ban Meta foto real -->
        <div class="product-image">
          <img src={raybanImage.src} alt="Ray-Ban Meta Smart Glasses" class="rayban-glasses" />
        </div>

        <!-- Form -->
        <div id="form-sorteio">
          <div data-tf-live="01KKXBM85WY536XZGFYVAXVPK8" style="width:100%;height:520px;"></div>
          <script is:inline src="https://embed.typeform.com/next/embed.js"></script>

          <div class="social-row" style="margin-top: 20px;">
            <a class="social-handle" href="https://www.linkedin.com/company/jaya-tech" target="_blank" rel="noopener">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="22" height="22" rx="5" fill="rgba(255,255,255,0.15)"/>
                <path d="M6.5 9H8.5V16H6.5V9ZM7.5 8C6.84 8 6.5 7.6 6.5 7C6.5 6.4 6.84 6 7.5 6C8.16 6 8.5 6.4 8.5 7C8.5 7.6 8.16 8 7.5 8ZM10 9H11.9V10C12.2 9.4 12.9 8.9 14 8.9C15.9 8.9 16.5 10 16.5 11.8V16H14.5V12.2C14.5 11.2 14.2 10.7 13.4 10.7C12.5 10.7 12 11.3 12 12.2V16H10V9Z" fill="white"/>
              </svg>
              /jaya-tech
            </a>
            <a class="social-handle" href="http://instagram.com/wearejaya/" target="_blank" rel="noopener">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="22" height="22" rx="5" fill="rgba(255,255,255,0.15)"/>
                <rect x="5.5" y="5.5" width="11" height="11" rx="3.2" stroke="white" stroke-width="1.4" fill="none"/>
                <circle cx="11" cy="11" r="2.6" stroke="white" stroke-width="1.4" fill="none"/>
                <circle cx="14.8" cy="7.2" r="0.8" fill="white"/>
              </svg>
              @wearejaya
            </a>
          </div>

          <p class="regras" style="margin-top: 16px;">
            <strong style="color: rgba(255,255,255,0.8);">Regras:</strong>
            O sorteio será realizado e divulgado após o último coffeebreak do evento Tropical on Rails,
            entre as pessoas que estiverem devidamente inscritas através do formulário acima até às 15h do dia 10/04
            e tenham feito e postado a foto solicitada com a #jayaTropicalOnRails e marcando devidamente os perfis
            da Jaya no LinkedIn ou no Instagram. Caso a pessoa vencedora não esteja no local enviaremos o prêmio
            pelo correio, após até 03 tentativas de contato via email cadastrado. Caso a pessoa vencedora não
            tenha tirado a foto faremos um segundo sorteio via live no Instagram da Jaya mediante anúncio de
            data e horário.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PERGUNTAS ─────────────────────────────────────────── -->
  <section style="background: var(--teal-dark); border-top: 1px solid var(--border-white);">
    <div class="perguntas">
      <h2 class="section-title">Perguntas</h2>
      <p class="section-intro">
        Na Jaya, acreditamos que a engenharia de software começa pelas pessoas e pelos valores
        que colocamos em prática todos os dias.
        <strong>Escolha uma das perguntas abaixo e deixe sua resposta no nosso painel:</strong>
      </p>

      <!-- Value cards -->
      <div class="cards-grid">
        <div class="value-card">
          <h3 class="value-title">Desenvolva sua<br/>próxima versão:</h3>
          <p class="value-desc">cresça por meio do aprendizado, do feedback e do autoconhecimento. progresso acima da perfeição.</p>
        </div>
        <div class="value-card">
          <h3 class="value-title">Ame o<br/>seu dia</h3>
          <p class="value-desc">encontre equilíbrio. faça o que você acredita. cuide de si e dos outros.</p>
        </div>
        <div class="value-card">
          <h3 class="value-title">Construa relações<br/>saudáveis:</h3>
          <p class="value-desc">valorize cada pessoa. comunique-se com respeito. abrace as diferenças.</p>
        </div>
      </div>

      <!-- Questions -->
      <div class="perguntas-grid">
        <div class="pergunta-item">
          <p class="pergunta-label">Pergunta 1</p>
          <p class="pergunta-text">O que você quer desenvolver em você este ano?</p>
        </div>
        <div class="pergunta-item">
          <p class="pergunta-label">Pergunta 2</p>
          <p class="pergunta-text">O que faz você amar o seu dia?</p>
        </div>
        <div class="pergunta-item">
          <p class="pergunta-label">Pergunta 3</p>
          <p class="pergunta-text">O que torna uma relação de trabalho saudável?</p>
        </div>
      </div>

      <div class="perguntas-cta">
        <a href="#form-sorteio" class="btn-pill" style="font-size: 0.95rem; padding: 14px 36px;">
          Participar do Sorteio
        </a>
      </div>
    </div>
  </section>

  <!-- ── VAGA + CULTURA ────────────────────────────────────── -->
  <section class="white-section" id="vaga">
    <div class="white-section-inner">

      <!-- Vaga Ruby -->
      <div>
        <p class="ws-label">oportunidade</p>
        <h2 class="ws-title">Vaga Ruby</h2>
        <p class="ws-subtitle">100% Remote &nbsp;|&nbsp; People-first &nbsp;|&nbsp; Driven by Impact</p>
        <div class="ws-body">
          <p>
            Se você trabalha com Ruby e busca um ambiente onde possa evoluir tecnicamente
