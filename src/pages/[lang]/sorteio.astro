  <!-- ── JS: smooth scroll to form ──────────────────────── -->
  <script>
    document.querySelectorAll('a[href="#form-sorteio"], a[href="#formulario"], a[href="#participar"]').forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const form = document.getElementById('form-sorteio');
        if (form) {
          form.scrollIntoView({ behavior: 'smooth', block: 'center' });
          setTimeout(() => {
            const first = form.querySelector('input');
            if (first) first.focus();
          }, 600);
        }
      });
    });

    // Intersection Observer for scroll reveals
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const target = e.target as HTMLElement;
          target.style.opacity = '1';
          target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.value-card, .pergunta-item, .ws-title, .ws-body').forEach(el => {
      const element = el as HTMLElement;
      element.style.opacity = '0';
      element.style.transform = 'translateY(20px)';
      element.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      observer.observe(element);
    });
  </script>

