---
import { getLocaleParam, localeBr } from '@/i18n/utils'
import { actions } from 'astro:actions'
import ContactPage from '../_shared/ContactPage.astro'

export const prerender = false // This page will be SSR (required for Actions)

export function getStaticPaths() {
	return [{ params: { lang: localeBr } }]
}

const lang = getLocaleParam(Astro.params.lang, [localeBr])
if (!lang) {
	return new Response(null, { status: 404 })
}

const result = Astro.getActionResult(actions.send)
---

<ContactPage locale={lang} action={actions.send} result={result} />
